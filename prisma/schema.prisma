// Prisma schema สำหรับระบบจองตั๋วฟุตบอลออนไลน์
// ใช้ PostgreSQL (Docker container `pattani_pg` บน port 5435)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin user สำหรับเข้าหลังบ้าน
// permissions = สิทธิ์เข้าหมวดต่าง ๆ (SUPER_ADMIN ข้ามการเช็คทั้งหมด)
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  role         Role         @default(ADMIN)
  permissions  Permission[] @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// สิทธิ์เข้าถึงแต่ละหมวดของหลังบ้าน
// SUPER_ADMIN มีทุกสิทธิ์เสมอ (bypass); ADMIN จะเข้าได้เฉพาะที่ถูก grant
enum Permission {
  MATCHES
  BOOKINGS
  SEASON_PASSES
  CUSTOMERS
  WEBSITE
  REPORTS
  FINANCE
  GATE_CHECK
  ACCOUNT
  MEMBER_DATA
  MATCH_RESULTS
  BARCODE_MANAGEMENT
}

// ลูกค้า (Customer) — แยกออกจาก User admin
// ใช้สำหรับสมัครสมาชิก ซื้อสินค้า/บัตร และดูกิจกรรมลุ้นรางวัล
// passwordHash = nullable เพราะบัญชี social-only ไม่ต้องมีรหัสผ่าน
// pdpaConsentAt = timestamp ที่ลูกค้ายอมรับนโยบายข้อมูลส่วนบุคคล (บังคับ)
model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  name            String
  phone           String?
  gender          String?
  birthDate       DateTime?
  address         String?
  province        String?
  district        String?
  postalCode      String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  pdpaConsentAt   DateTime?
  accounts        CustomerAccount[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
}

// บัญชีจาก provider ภายนอก (Google / Line) ผูกกับ Customer
// 1 Customer ผูกได้หลาย provider — auto-link ด้วยอีเมล
model CustomerAccount {
  id                String       @id @default(cuid())
  customerId        String
  customer          Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider          AuthProvider
  providerAccountId String
  providerEmail     String?
  linkedAt          DateTime     @default(now())

  @@unique([provider, providerAccountId])
  @@index([customerId])
}

enum AuthProvider {
  GOOGLE
  LINE
}

// แมตช์ฟุตบอล
// fields ที่ optional (venue/kickoffAt/totalSeats/pricePerSeat) เพื่อให้
// admin บันทึก "ฉบับร่าง" ได้แม้ข้อมูลยังไม่ครบ
// แต่ก่อนเปลี่ยนเป็น ON_SALE ระบบจะบังคับให้ครบทุก field (validate ที่ schema)
model Match {
  id            String      @id @default(cuid())
  homeTeam      String
  awayTeam      String
  homeTeamLogo  String?     // path เช่น /uploads/matches/<uuid>.png (validate ที่ Zod)
  awayTeamLogo  String?
  venue         String?
  kickoffAt     DateTime?
  totalSeats    Int?
  zone170Seats  Int?
  zone150Seats  Int?
  zone120Seats  Int?
  zone100Seats  Int?
  zoneAwaySeats Int?
  pricePerSeat  Int?        // ราคาเป็นสตางค์ (เลี่ยง floating point)
  competitionType CompetitionType @default(LEAGUE)
  homeScore     Int?
  awayScore     Int?
  status        MatchStatus @default(SCHEDULED)
  description   String?
  bookings      Booking[]
  seasonPassScans SeasonPassScan[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([kickoffAt])
  @@index([status])
}

model LeagueTeam {
  id        String   @id @default(cuid())
  name      String   @unique
  logo      String?
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CompetitionType {
  LEAGUE
  CUP
}

enum MatchStatus {
  SCHEDULED
  ON_SALE
  SOLD_OUT
  CANCELLED
  FINISHED
}

// การจองตั๋ว
// customerEmail = nullable เพื่อรองรับ guest checkout (ไม่ต้องสมัครสมาชิก)
// member จะมี email จาก session, guest จะเป็น null
model Booking {
  id              String        @id @default(cuid())
  bookingCode     String        @unique @default(cuid())
  matchId         String
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Restrict)
  customerName    String
  customerEmail   String?       // guest = null, member = session email
  customerPhone   String
  quantity        Int
  zone            String?
  totalAmount     Int           // ราคารวม (สตางค์)
  status          BookingStatus @default(PENDING)
  paymentMethod   String?       // "PROMPTPAY" | "MOBILE_BANKING" | "CREDIT_CARD"
  paidAt          DateTime?
  seatNumbers     String[]      // ที่นั่งที่ออกให้ เช่น ["A-101","A-102"]
  notes           String?
  // เวลา scan ครั้งแรก (คงไว้รองรับระบบ gate-check แบบเดิม)
  // รายการ scan รายใบอยู่ใน gateScans เพื่อรองรับ booking ที่มีหลายใบ
  scannedAt       DateTime?
  scannedBy       String?       // userId ของ admin ที่กด scan (เก็บไว้ audit)
  gateScans       BookingGateScan[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([matchId])
  @@index([matchId, zone])
  @@index([status])
  @@index([customerEmail])
  @@index([customerPhone])
  @@index([scannedAt])
}

// OTP สำหรับยืนยันเบอร์โทรก่อนแสดงรายการจองและ E-Ticket
// providerToken เก็บเฉพาะฝั่งเซิร์ฟเวอร์ ส่วนเบราว์เซอร์เก็บเพียง id ใน httpOnly cookie
model BookingSearchOtp {
  id            String    @id @default(cuid())
  phone         String
  providerToken String
  reference     String?
  attempts      Int       @default(0)
  verifiedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

// หนึ่ง booking อาจมีหลายใบ จึงบันทึกการผ่านประตูแยกเป็นรายครั้ง
// เพื่ออนุญาตการสแกนได้สูงสุดเท่ากับ quantity ของการจองนั้น
model BookingGateScan {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  scannedAt   DateTime @default(now())
  scannedBy   String

  @@index([bookingId, scannedAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

// ออเดอร์ร้านค้าออนไลน์
// แยก order code ออกจาก id เพื่อใช้เปิดเผยใน URL ได้ (ไม่หลุด PK)
// ราคา/ชื่อสินค้าทุกบรรทัด snapshot ลงในแถว ShopOrderItem
// — กันสินค้าหรือราคาใน CMS เปลี่ยนหลังจากออเดอร์ถูกสร้าง
model ShopOrder {
  id              String              @id @default(cuid())
  orderCode       String              @unique @default(cuid())
  // customer (รองรับทั้ง guest + member; member จะมี customerEmail จาก session)
  customerName    String
  customerPhone   String
  customerEmail   String?
  // shipping address (nullable เพื่อรองรับ PICKUP)
  shippingMethod  ShopShippingMethod
  shippingFee     Int                 // satang
  shipAddress     String?
  shipCity        String?
  shipProvince    String?
  shipPostalCode  String?
  shipNote        String?
  // money (ทุก field เก็บเป็นสตางค์ — กัน floating point)
  subtotal        Int                 // ผลรวมของ items
  totalAmount     Int                 // subtotal + shippingFee
  // payment
  paymentMethod   ShopPaymentMethod
  paidAt          DateTime?
  // fulfillment
  status          ShopOrderStatus     @default(PENDING)
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelReason    String?
  notes           String?
  items           ShopOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([customerPhone])
  @@index([customerEmail])
}

model ShopOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       ShopOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // snapshot จาก Payload products (productId เก็บเป็น string เพราะ Payload อาจเป็น number/string)
  productId   String
  productName String
  imageUrl    String?
  unitPrice   Int        // ราคาเป็นสตางค์
  quantity    Int
  size        String?
  lineTotal   Int        // unitPrice * quantity (snapshot)
  createdAt   DateTime   @default(now())

  @@index([orderId])
}

enum ShopOrderStatus {
  PENDING         // ยังไม่ชำระ
  PAID            // ชำระแล้ว รอจัดส่ง
  PROCESSING      // กำลังเตรียมพัสดุ
  SHIPPED         // จัดส่งแล้ว
  DELIVERED       // ส่งถึงปลายทาง
  CANCELLED
  REFUNDED
}

enum ShopShippingMethod {
  STANDARD        // ไปรษณีย์ไทย / EMS — 50 บาท
  EXPRESS         // Kerry / Flash — 80 บาท
  PICKUP          // รับเองที่สนาม — ฟรี
}

enum ShopPaymentMethod {
  PROMPTPAY
  BANK_TRANSFER
  COD             // เก็บปลายทาง
}

// บัตรสมาชิกรายปี (Season Pass)
// tier + priceBaht + shippingFeeBaht เป็น snapshot ตอนซื้อ — กันราคาเปลี่ยนแล้วกระทบออเดอร์เก่า
// customerId nullable = รองรับ guest checkout (member จะ link ผ่าน customerId)
// deliveryMethod = SHIPPING → ต้องมี shipAddress; PICKUP → ต้องมี pickupLocation
model SeasonPassOrder {
  id               String                    @id @default(cuid())
  passCode         String                    @unique
  tierId           String                    // "vvip-elite" | "vip-advanced" | "premium" | "gold"
  seatZone         String
  seasonLabel      String                    // "2026/27"
  priceBaht        Int                       // สแนปช็อตราคาบัตร ณ วันซื้อ
  shippingFeeBaht  Int                       @default(0)
  // customer
  customerId       String?
  customerName     String
  customerPhone    String
  customerEmail    String?
  // delivery
  deliveryMethod   SeasonPassDeliveryMethod  @default(PICKUP)
  shipAddress      String?
  shipCity         String?
  shipProvince     String?
  shipPostalCode   String?
  shirtSize        String?
  shipNote         String?
  pickupLocation   String?
  // payment / status
  paymentMethod    String                    // "card" | "promptpay" | "banking"
  status           SeasonPassOrderStatus     @default(CONFIRMED)
  notes            String?
  barcode          SeasonPassBarcode?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([status])
  @@index([customerPhone])
  @@index([customerEmail])
  @@index([customerId])
}

model SeasonPassBarcode {
  id            String            @id @default(cuid())
  barcode       String            @unique
  tierId        String
  seasonLabel   String
  isGenerated   Boolean           @default(false)
  usesRemaining Int               @default(15)
  orderId       String?           @unique
  order         SeasonPassOrder?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedAt    DateTime?
  scans         SeasonPassScan[]
  createdAt     DateTime          @default(now())

  @@index([tierId, orderId])
  @@index([tierId, isGenerated, orderId])
}

model SeasonPassScan {
  id          String            @id @default(cuid())
  barcodeId   String
  barcode     SeasonPassBarcode @relation(fields: [barcodeId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match             @relation(fields: [matchId], references: [id], onDelete: Restrict)
  scannedAt   DateTime          @default(now())
  scannedBy   String

  @@unique([barcodeId, matchId])
  @@index([matchId])
}

enum SeasonPassOrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum SeasonPassDeliveryMethod {
  SHIPPING   // +50 บาท — ส่งบัตรสมาชิกทางไปรษณีย์
  PICKUP     // ฟรี — รับด้วยตัวเองที่จุดรับ
}
